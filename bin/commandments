#!/usr/bin/env php
<?php

declare(strict_types=1);

use JesseGall\CodeCommandments\Cli\Judge;

(static function (array $argv): void {
    foreach ([
        __DIR__ . '/../vendor/autoload.php',   // run from the package
        __DIR__ . '/../../../autoload.php',     // run as vendor/bin in a consumer
    ] as $autoload) {
        if (is_file($autoload)) {
            require $autoload;
            break;
        }
    }

    $command = $argv[1] ?? 'judge';
    $args = array_slice($argv, 2);

    if (in_array($command, ['-h', '--help', 'help'], true)) {
        fwrite(STDOUT, <<<TXT
        Code Commandments — a compiler for architecture.

        Usage:
          commandments judge [path] [--skill=NAME] [--detector=NAME]
          commandments judge --list
          commandments install  # wire the composer post-update hook, then sync
          commandments sync     # publish skills + refresh the CLAUDE.md briefing

        Options:
          --skill=NAME       only run detectors for one skill (group), e.g. spatie-data
          --detector=NAME    only run one detector (partial name match)
          --exclude=A,B      skip findings in paths containing any fragment
          --list             list every detector grouped by skill

        Files marked @code-commandments-generated are skipped automatically
        (they are regenerated, not hand-authored). Exit code 1 when sins found.

        TXT);

        exit(0);
    }

    exit(match ($command) {
        'judge' => (new Judge)->run($args),
        'sync' => (new JesseGall\CodeCommandments\Cli\Sync)->run($args),
        'install' => (new JesseGall\CodeCommandments\Cli\Install)->run($args),
        default => (static function () use ($command): int {
            fwrite(STDERR, "Unknown command '{$command}'. Try: commandments --help\n");

            return 2;
        })(),
    });
})($argv);
