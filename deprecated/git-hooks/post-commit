#!/bin/sh
#
# Pull the latest open [prophet-report] issues from GitHub after each commit, so
# new reports surface right in the commit output and get triaged, not forgotten.
# Installed locally (not version-controlled). Stays silent without gh/network.

command -v gh >/dev/null 2>&1 || exit 0

repo="jessegall/code-commandments"

reports=$(gh issue list --repo "$repo" --state open --json number,title \
  --jq '.[] | select(.title | startswith("[prophet-report]")) | "  #\(.number): \(.title)"' 2>/dev/null)

[ -z "$reports" ] && exit 0

printf '\n📋 Open prophet reports to triage (pulled from %s):\n%s\n' "$repo" "$reports"
exit 0
