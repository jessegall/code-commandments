{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/grind-engine.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/engine-pulse.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/elegance-pulse.sh" }
        ]
      }
    ]
  }
}
