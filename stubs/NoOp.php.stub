<?php

declare(strict_types=1);

namespace {namespace};

/**
 * The do-nothing {@see Invokable} — the Null Object for an optional callback, so a slot
 * that "might have a callback" defaults to behaviour (a harmless no-op), never null.
 * Default an optional-callback parameter to `new NoOp` and just call it.
 */
final class NoOp implements Invokable
{
    public function __invoke(mixed ...$arguments): mixed
    {
        return null;
    }
}
