namespace {{ namespace }};

/**
 * True when every wrapped predicate is true (logical AND). An empty set is
 * vacuously true. Built by {@see Predicate::and()} or `AllOf::of(...)`.
 *
 * Generated by code-commandments — safe to edit.
 *
 * @code-commandments-generated
 *
 * @template TIn
 *
 * @extends Predicate<TIn>
 */
final class AllOf extends Predicate
{

    /** @var list<Predicate<mixed>> */
    private readonly array $predicates;

    /**
     * @param  Predicate<TIn>  $first
     * @param  Predicate<mixed>  ...$rest
     */
    private function __construct(Predicate $first, Predicate ...$rest)
    {
        $this->predicates = [$first, ...array_values($rest)];
    }

    /**
     * The first predicate drives the input type; the rest stay `mixed`, so
     * `Predicate<TIn>::and()` preserves TIn without a cast.
     *
     * @template T
     *
     * @param  Predicate<T>  $first
     * @param  Predicate<mixed>  ...$rest
     * @return self<T>
     */
    public static function of(Predicate $first, Predicate ...$rest): self
    {
        return new self($first, ...$rest);
    }

    public function __invoke(mixed $value): bool
    {
        foreach ($this->predicates as $predicate)
        {
            if (! $predicate($value))
            {
                return false;
            }
        }

        return true;
    }

}
