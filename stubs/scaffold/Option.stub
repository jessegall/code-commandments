     * to wrap a bare value).
     *
     * @template TWhen
     *
     * @param  callable(): self<TWhen>  $factory
     * @return self<TWhen>
     */
    public static function when(mixed $condition, callable $factory): self
    {
        return $condition ? $factory() : self::none();
    }

    /**
     * The factory's option unless the condition is truthy, otherwise none.
     *
     * @template TWhenNot
     *
     * @param  callable(): self<TWhenNot>  $factory
     * @return self<TWhenNot>
     */
    public static function whenNot(mixed $condition, callable $factory): self
    {
        return $condition ? self::none() : $factory();
    }

    /**
     * `some($factory())` when the condition is truthy, otherwise none — the
     * value-wrapping form: the factory returns the bare value T and this wraps
