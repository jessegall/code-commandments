     * `Option::some(...)` boilerplate.
     *
     * @template TWhen
     *
     * @param  callable(): TWhen  $factory
     * @return self<TWhen>
     */
    public static function someWhen(mixed $condition, callable $factory): self
    {
        return $condition ? self::some($factory()) : self::none();
    }

    /**
     * `some($factory())` unless the condition is truthy, otherwise none.
     *
     * @template TWhen
     *
     * @param  callable(): TWhen  $factory
     * @return self<TWhen>
     */
    public static function someWhenNot(mixed $condition, callable $factory): self
    {
        return $condition ? self::none() : self::some($factory());
    }
}
