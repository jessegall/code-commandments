/**
 * The value-or-nothing twin of {@see ScalarUnion}: a present-or-absent scalar
 * (`string | int | float | bool`). The named home for a nullable scalar — a
 * `string | int | float | bool | null` union — where the `null` IS the absence
 * and the rest is the present scalar. Reach for it instead of returning
 * `?string` / `int | null` from a config lookup, a cell value, an env read.
 *
 *     $port = ScalarOption::some(8080);
 *     $port = ScalarOption::none();          // absent — not null
 *
 *     $value = $port->getOr('default');      // string|int|float|bool|'default'
 *
