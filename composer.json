{
    "name": "jessegall/code-commandments",
    "description": "An architecture compiler for PHP — single-concern discipline prophets that judge a codebase against a configurable style and architecture spec",
    "keywords": [
        "laravel",
        "code-quality",
        "static-analysis",
        "architecture",
        "commandments"
    ],
    "type": "library",
    "bin": [
        "bin/commandments"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jesse Gall",
            "email": "jessegall@example.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "nikic/php-parser": "^5.0",
        "jessegall/php-types": "^1.12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "JesseGall\\CodeCommandments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JesseGall\\CodeCommandments\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "readme": "@php scripts/generate-readme.php",
        "judge": "@php bin/commandments judge"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
